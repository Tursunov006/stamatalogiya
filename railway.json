{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python manage.py migrate && python manage.py collectstatic --noinput && gunicorn config.wsgi --bind 0.0.0.0:$PORT"
  },
  "environments": [
    {
      "name": "production",
      "envVars": [
        {
          "name": "DEBUG",
          "value": "False"
        },
        {
          "name": "SECRET_KEY",
          "value": "your-production-secret-key-change-this"
        },
        {
          "name": "DJANGO_SETTINGS_MODULE",
          "value": "config.settings_prod"
        }
      ]
    }
  ]
}